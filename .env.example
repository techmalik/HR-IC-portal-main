# Copy to .env and fill in real values. Never commit .env.

# ── Required ────────────────────────────────────────────────────────────────
# PostgreSQL connection string (Drizzle ORM)
DATABASE_URL=postgresql://user:password@localhost:5432/teamflow

# ── Email (Resend) ───────────────────────────────────────────────────────────
# Obtain at https://resend.com/api-keys
RESEND_API_KEY=re_...
# "From" address — must be a verified sender in your Resend account
FROM_EMAIL=notifications@yourdomain.com

# ── App URL ──────────────────────────────────────────────────────────────────
# Used for password-reset email links (falls back to REPLIT_DOMAINS in prod)
APP_URL=http://localhost:5000

# ── Platform / Super-admin ────────────────────────────────────────────────────
# Comma-separated list of emails that get platform-admin privileges
PLATFORM_ADMIN_EMAILS=admin@yourdomain.com

# ── Replit Object Storage (optional) ─────────────────────────────────────────
# Set automatically by Replit; only needed when self-hosting with GCS backend
# PRIVATE_OBJECT_DIR=.private
# PUBLIC_OBJECT_SEARCH_PATHS=.private/uploads

# ── Runtime ──────────────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=development
